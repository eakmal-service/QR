// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model QRCode {
  id          String   @id @default(cuid())
  businessId  String
  businessName String
  businessCategory String?
  businessType String? // e.g., b2b, b2c
  productSummary String?
  description String? // Detailed description of the business
  googleMapsLink String?
  location    String?
  menuItems   String?  // JSON array of menu/service items
  metadata    String?  // JSON for additional info
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  tempReviews TempReview[]
  reviews     Review[]
  scanLogs    ScanLog[]
}

model TempReview {
  id          String   @id @default(cuid())
  jobId       String   @unique
  qrCodeId    String
  qrCode      QRCode   @relation(fields: [qrCodeId], references: [id])
  reviewText  String
  language    String
  rating      Int
  hash        String   @unique
  embedding   String?  // JSON array of embedding vector
  sessionId   String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime
}

model Review {
  id          String   @id @default(cuid())
  qrCodeId    String
  qrCode      QRCode   @relation(fields: [qrCodeId], references: [id])
  reviewText  String
  language    String
  rating      Int
  source      String   @default("auto-gemini")
  metadata    String?  // JSON for additional info
  createdAt   DateTime @default(now())
}

model ScanLog {
  id          String   @id @default(cuid())
  qrCodeId    String
  qrCode      QRCode   @relation(fields: [qrCodeId], references: [id])
  jobId       String?
  deviceType  String?
  ipHash      String?
  userAgent   String?
  action      String   // e.g., "scan", "review_generated", "review_submitted"
  timestamp   DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
